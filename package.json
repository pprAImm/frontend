{
  "name": "ai-serial-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Фронтенд платформы для просмотра ИИ-сериалов",
  "scripts": {
    "dev": "npx serve . --listen 8080 --no-clipboard",
    "dev:login": "npx serve . --listen 8080 --no-clipboard",
    "dev:central": "npx serve . --listen 8080 --no-clipboard",
    "lint": "npx eslint **/*.js",
    "format": "npx prettier --write **/*.{js,css,html}"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.3",
    "serve": "^14.2.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}